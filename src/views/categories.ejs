<%- include('partials/header') %>

    <main>
        <h1>
            <%= title %>
        </h1>

        <h3>We want to connect your business website around the globe.</h3>

        <!-- ✅ Dynamic categories instead of hardcoded -->
        <ul>
            <% categories.forEach(category=> { %>
                <li>
                    <a href="#">
                        <%= category.name %>
                    </a>
                </li>
                <% }); %>
        </ul>

        <p></p>

        <img class="main-logo" src="images/image_cat.webp" alt="CSE 340 Backend Categories">

    </main>

    <%- include('partials/footer') %>