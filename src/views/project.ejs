<%- include('partials/header') %>

<main>


<h1><%= title %></h1>

<!-- Project Details -->
<section class="project-details">

    <h2><%= project.title %></h2>

    <p>
        <strong>Description:</strong><br>
        <%= project.description %>
    </p>

    <p>
        <strong>Location:</strong>
        <%= project.location %>
    </p>

    <p>
        <strong>Date:</strong>
        <%= project.project_date ? new Date(project.project_date).toDateString() : 'No date provided' %>
    </p>

    <!-- Organization link -->
    <% if (project.organization_id && project.organization_name) { %>
        <p>
            <strong>Organization:</strong>
            <a href="/organization/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>
    <% } %>

    <!-- Edit button -->
    <a href="/edit-project/<%= project.project_id %>">
        Edit Project
    </a>

</section>


</main>

<%- include('partials/footer') %>
