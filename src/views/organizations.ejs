<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>

    <h3>
        We connect you and your business to international wealthy partners attracting the right influence.
    </h3>

    <img class="main-logo" src="/images/image_org.webp" alt="CSE 340 Backend Organizations">

    <section>
        <h2>Our Partner Organizations</h2>

        <ul>
            <% organizations.forEach(organization => { %>
                <li style="margin-bottom: 20px;">

                    <!-- Logo -->
                    <img 
                        src="/images/<%= organization.logo_filename || 'default.png' %>" 
                        alt="<%= organization.name %> logo"
                        width="100"
                        style="display:block; margin-bottom:10px;"
                    >

                    <!-- Name -->
                    <strong><%= organization.name %></strong><br>

                    <!-- Description -->
                    <p><%= organization.description %></p>

                    <!-- Email -->
                    <p><%= organization.contact_email %></p>

                    <!-- Link to details page -->
                    <a href="/organization/<%= organization.organization_id %>">
                        View Details
                    </a>

                </li>
            <% }); %>
        </ul>
    </section>

</main>

<%- include('partials/footer') %>