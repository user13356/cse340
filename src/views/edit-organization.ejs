<%- include('partials/header') %>

<main>
    <h1>Edit Organization</h1>

    <h3>Update the details of this partner organization.</h3>

    <!-- ERROR MESSAGES -->
    <% if (errors && errors.length > 0) { %>
        <% errors.forEach(function(e) { %>
            <p style="color:red;"><%= e %></p>
        <% }) %>
    <% } %>

    <section>
        <h2>Organization Details</h2>

        <form action="/edit-organization/<%= organization.organization_id %>" method="POST">

            <!-- Name -->
            <div>
                <label for="name">Organization Name</label><br>
                <input
                    type="text"
                    id="name"
                    name="name"
                    value="<%= (formData && formData.name) || organization.name %>"
                    required
                >
            </div>

            <!-- Description -->
            <div>
                <label for="description">Description</label><br>
                <textarea
                    id="description"
                    name="description"
                    rows="4"
                    required
                ><%= (formData && formData.description) || organization.description %></textarea>
            </div>

            <!-- Email -->
            <div>
                <label for="contact_email">Contact Email</label><br>
                <input
                    type="email"
                    id="contact_email"
                    name="contact_email"
                    value="<%= (formData && formData.contact_email) || organization.contact_email %>"
                    required
                >
            </div>

            <!-- Website -->
            <div>
                <label for="website">Website</label><br>
                <input
                    type="url"
                    id="website"
                    name="website"
                    value="<%= (formData && formData.website) || organization.website %>"
                >
            </div>

            <!-- Logo -->
            <div>
                <label for="logo_filename">Logo Filename</label><br>
                <input
                    type="text"
                    id="logo_filename"
                    name="logo_filename"
                    value="<%= (formData && formData.logo_filename) || organization.logo_filename %>"
                >
            </div>

            <br>

            <button type="submit">Update Organization</button>
        </form>
    </section>
</main>

<%- include('partials/footer') %>