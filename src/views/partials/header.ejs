<link rel="stylesheet" href="/css/main.css">

<nav class="main-nav">
    <a class="nav-btn" href="/">🏠 Home</a>
    <a class="nav-btn" href="/dashboard">Dashboard</a>

    <% if (typeof user !== 'undefined' && user) { %>

        <a class="nav-btn" href="/organizations">Organizations</a>
        <a class="nav-btn" href="/organizations/new">Add Organization</a>

        <a class="nav-btn" href="/projects">Projects</a>
        <a class="nav-btn" href="/projects/new">Add Project</a>

        <a class="nav-btn" href="/categories">Categories</a>
        <a class="nav-btn" href="/categories/add">Add Category</a>

        <% if (user.role === 'admin') { %>
            <a class="nav-btn" href="/users">Users</a>
        <% } %>

        <span class="nav-text">Welcome, <%= user.name %></span>

        <a class="nav-btn danger" href="/logout">Logout</a>

    <% } else { %>

        <a class="nav-btn" href="/login">Login</a>
        <a class="nav-btn" href="/register">Register</a>

    <% } %>
</nav>